<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Debug-only cleartext support for local Android testing.
      Android network security config cannot express CIDR IP ranges, so the
      cleartext allowance is kept scoped to the debug build variant only.
    -->
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
