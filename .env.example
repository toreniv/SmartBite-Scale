# Server-only Gemini key. Set this on the Next.js/backend environment only.
GEMINI_API_KEY=your_server_only_gemini_api_key

# Public API base URL used by the frontend.
# Local development:
# Leave empty to use the local Next.js route at /api/analyze.
NEXT_PUBLIC_API_BASE_URL=

# Production / Capacitor mobile build:
# Point this to your deployed backend so static builds can call /api/analyze externally.
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.com
