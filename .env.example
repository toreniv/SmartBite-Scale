# SmartBite Scale environment example

# Static export mode for Capacitor / Android builds
NEXT_OUTPUT_MODE=export

# Backend base URL used when direct Gemini mode is disabled
NEXT_PUBLIC_API_BASE_URL=http://192.168.1.152:3001

# Allow mock analysis only when you explicitly want demo fallback
ALLOW_MOCK_ANALYSIS_FALLBACK=false

# Server-side AI providers used by the backend
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# Optional backend settings
PORT=3001
RATE_LIMIT_MAX=10

# Optional CORS allowlist for backend dev
# CORS_ALLOWED_ORIGINS=http://localhost:3000,capacitor://localhost

# Client-side direct Gemini mode for field testing only
NEXT_PUBLIC_GEMINI_DIRECT=false
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_key_here
