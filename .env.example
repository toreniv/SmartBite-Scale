# Server-only Gemini key. Set this on the Next.js/backend environment only.
GEMINI_API_KEY=your_server_only_gemini_api_key

# Build mode for this Next.js app.
# Use "export" for static web / Capacitor builds.
# Use "server" for a hosted Next.js deployment that should expose /api/analyze.
NEXT_OUTPUT_MODE=export

# Public API base URL used by the frontend.
# Local development:
# Leave empty to use the local Next.js route at /api/analyze.
NEXT_PUBLIC_API_BASE_URL=

# Production / Capacitor mobile build:
# Point this to your deployed backend so static builds can call /api/analyze externally.
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.com

# Optional, comma-separated CORS allow-list for cross-origin calls to the backend.
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost,capacitor://localhost,https://your-web-app-domain.com

# Optional safety switch.
# In local development you can leave this unset and mock fallback stays available.
# In production, keep it unset or set it to false so Gemini failures return real API errors.
# ALLOW_MOCK_ANALYSIS_FALLBACK=false
